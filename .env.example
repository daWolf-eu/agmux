# agmux environment overrides — copy to .env and edit as needed.
# All are optional; defaults assume the compiled binaries are on your PATH.

# Path/command agmux uses to spawn the background hub (default: agmux-hub on PATH).
# AGMUX_HUB_BIN=/usr/local/bin/agmux-hub

# Path/command agmux uses to spawn the PTY wrapper (default: agmux-wrap on PATH).
# AGMUX_WRAP_BIN=/usr/local/bin/agmux-wrap

# The agmux binary the runtime re-invokes for callbacks (default: agmux on PATH).
# AGMUX_BIN=/usr/local/bin/agmux

# tmux session name used by the wrapper (default: agmux). Override for test isolation.
# AGMUX_TMUX_SESSION=agmux
